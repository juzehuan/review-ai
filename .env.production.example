# ──────────────────────────────────────────────────────────
# 生产环境配置模板
# 部署时复制为 .env.production 并填入实际值，切勿将该文件提交到 git
# ──────────────────────────────────────────────────────────

# === 必填：数据库密码 ===
# 用强随机串，例：openssl rand -base64 32
POSTGRES_PASSWORD=please-change-me-to-a-strong-random-password

# === 可选：数据库其他参数（一般保留默认） ===
# POSTGRES_DB=review_ai
# POSTGRES_USER=postgres

# === 可选：Web 对外端口（默认 80） ===
# 如果服务器 80 被占用或要在反代后面，可改为 8080
# WEB_PORT=8080

# === AI 模型默认配置（仅作为初始 fallback） ===
# 部署后，AI Provider / API Key / Prompt 都通过 Web 端 「设置」 页面动态配置并写入数据库
# 下面的值仅在 ai_config 表为空、且系统首次接到分析任务时使用
AI_PROVIDER=volcengine

# 火山引擎 ARK
VOLC_ARK_API_KEY=
VOLC_MODEL=doubao-seed-2-0-code-preview-260215

# OpenAI（可选）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# false = 调用真实 AI；true = 用规则 mock（仅本地调试，生产请关闭）
ENABLE_MOCK_AI=false

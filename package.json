{
  "name": "review-ai-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @review-ai/web dev",
    "dev:api": "pnpm --filter @review-ai/api dev",
    "dev:worker": "pnpm --filter @review-ai/worker dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @review-ai/db prisma:generate",
    "db:migrate": "pnpm --filter @review-ai/db prisma:push"
  }
}

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/review_ai
REDIS_URL=redis://redis:6379

# AI 提供商选择：volcengine（火山引擎）或 openai（默认）
# 留空所有 API Key 时自动使用 Mock 分析
AI_PROVIDER=volcengine

# 火山引擎 ARK 配置
# API Key 在火山引擎控制台 → 方舟 → API Key 管理 获取
VOLC_ARK_API_KEY=
# 模型填写 Endpoint ID（ep-xxxx）或模型名（如 doubao-pro-32k）
VOLC_MODEL=doubao-pro-32k-241215

# OpenAI 配置（AI_PROVIDER=openai 时生效）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# true = 强制使用规则 Mock 分析（不调用任何 AI API，适合本地调试）
ENABLE_MOCK_AI=true
